# API Configuration
EXPO_PUBLIC_API_URL=https://contestnepal.com/api

# Google OAuth Configuration
# Get this from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
EXPO_PUBLIC_GOOGLE_CLIENT_ID=259496528379-pi5pcg6bc38pl20d59h4ifndirhdvr9e.apps.googleusercontent.com

# MUST match the redirect URI registered in Google Cloud Console
# For Android: com.soriful420.contest_hub:/oauth2redirect
# For iOS: com.yourcompany.contestnepal:/oauth2redirect (or your bundle ID)
# Or use your backend URL: https://your-api.com/auth/callback
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=https://contestnepal.com/api/auth/callback

# Development Settings
NODE_ENV=development